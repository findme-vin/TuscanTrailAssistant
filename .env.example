# Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Hotel search — set HOTEL_PROVIDER to switch: "serpapi" (default) or "hotelbeds"
HOTEL_PROVIDER=serpapi
EXPO_PUBLIC_HOTEL_SEARCH_ENABLED=true

# SerpApi (https://serpapi.com/) — server-side only
SERPAPI_KEY=your_serpapi_key_here

# HotelBeds (https://developer.hotelbeds.com/) — only needed if HOTEL_PROVIDER=hotelbeds
EXPO_PUBLIC_HOTELBEDS_API_KEY=your_api_key_here
EXPO_PUBLIC_HOTELBEDS_SECRET=your_secret_here
EXPO_PUBLIC_HOTELBEDS_ENV=test

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123
